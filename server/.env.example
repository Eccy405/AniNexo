# URL de conexión a la base de datos MySQL (con Prisma)
DATABASE_URL="mysql://username:password@localhost:3306/aninexo"

# Puerto en el que correrá el servidor Backend
PORT=3001

# Clave de API de OpenAI (para las funciones de IA de Nexo)
OPENAI_API_KEY="tu_openai_api_key_aqui"

# Llave secreta para firmar tokens JWT
JWT_SECRET="tu_jwt_secret_muy_seguro_aqui"

# Configuración de Correo (Gmail SMTP) para envío de códigos de verificación
MAIL_USER="tu_correo_gmail@gmail.com"
MAIL_PASS="tu_contraseña_de_aplicacion_gmail_aquí"

# Opciones adicionales de OAuth (Google y Discord)
GOOGLE_CLIENT_ID="tu_google_client_id_aqui"
GOOGLE_CLIENT_SECRET="tu_google_client_secret_aqui"
DISCORD_CLIENT_ID="tu_discord_client_id_aqui"
DISCORD_CLIENT_SECRET="tu_discord_client_secret_aqui"

# URL del Frontend (Next.js) y Secretos de Sesión
CLIENT_URL="http://localhost:3000"
SESSION_SECRET="tu_session_secret_muy_seguro_aqui"

